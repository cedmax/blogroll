# Cloudflare Turnstile server-side secret — set in Netlify dashboard, not GitHub secrets
TURNSTILE_SECRET=

# GitHub fine-grained PAT — repo cedmax/blogroll, issues:write scope only
# (used only for creating issues; OPML duplicate check reads a bundled file, no token needed)
GITHUB_TOKEN=

# Cloudflare Turnstile sitekey (public — baked into the static build by Astro)
PUBLIC_TURNSTILE_SITEKEY=
