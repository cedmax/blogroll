---
import "../styles/global.css"

interface Props {
  title: string
  description?: string
  canonical: string
  activeNav: "home" | "timeline" | ""
  opmlFile: string
}
const { title, description, canonical, activeNav, opmlFile } = Astro.props
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="cedmax" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/opml+xml"
      title="Blogroll.it OPML"
      href={`https://blogroll.it/${opmlFile}`}
    />
    <meta name="theme-color" content="#D6EED8" />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📡</text></svg>"
    />
    <slot name="head" />
  </head>
  <body class="bg-bg text-ink font-sans text-base leading-normal min-h-screen">
    <div class="max-w-4xl mx-auto px-5 pt-8 pb-16">
      <header
        class="flex items-center justify-between flex-wrap gap-x-4 gap-y-2 mb-10 pb-4 border-b border-border"
      >
        <a
          class="text-xl font-bold tracking-tight text-green no-underline hover:text-green-h"
          href="/">Blogroll.it</a
        >
        <nav class="flex gap-5 text-xs">
          <a
            class="text-ink-mid no-underline hover:text-green hover:underline"
            href={`/${opmlFile}`}>OPML</a
          >
        </nav>
      </header>

      <slot name="meta-line" />

      <slot />

      <footer class="mt-12 pt-4 border-t border-border text-xs text-ink-muted">
        <a
          class="text-green no-underline hover:text-green-h hover:underline"
          href="https://github.com/cedmax/blogroll/issues">Suggerisci un blog</a
        > aprendo una issue o una PR su <a
          class="text-green no-underline hover:text-green-h hover:underline"
          href="https://github.com/cedmax/blogroll">GitHub</a
        >.
      </footer>
    </div>
  </body>
</html>
