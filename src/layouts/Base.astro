---
import "../styles/global.css"
import ReportDialog from "../components/ReportDialog.astro"
import Logo from "../components/Logo.astro"
import Nav from "../components/Nav.astro"

import { opmlFile } from "../utils/feeds"

interface Props {
  title: string
  description?: string
  canonical: string
  activeNav: "home" | "lista" | "info" | ""
}
const { title, description, canonical, activeNav } = Astro.props
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="cedmax" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/opml+xml"
      title="blogroll.it OPML"
      href={`https://blogroll.it/${opmlFile}`}
    />
    <meta name="theme-color" content="#f5f0e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#15171a" media="(prefers-color-scheme: dark)" />
    <script is:inline>
      const t = localStorage.getItem("theme")
      if (t) document.documentElement.dataset.theme = t
    </script>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>
  <body class="bg-bg text-ink font-sans text-base leading-normal min-h-screen">
    <div class="max-w-4xl mx-auto px-5 pt-8 pb-16">
      <header
        class="flex relative items-center justify-between flex-wrap gap-x-4 gap-y-2 mb-16 pb-4 border-b border-border"
      >
        <a class="text-4xl flex font-black tracking-tighter no-underline" href="/">
          <Logo />
          <span class="-ml-0.5 mt-px">blogroll.it</span></a
        >

        <Nav activeNav={activeNav} />

        <div class="absolute -bottom-6 w-full">
          <slot name="meta-line" />
        </div>
      </header>

      <slot />

      <footer class="mt-12 pt-4 text-right border-t border-border text-xs text-ink-muted">
        <a href="/proposte/">Suggerisci un sito</a>.
      </footer>
    </div>

    <ReportDialog />
  </body>
</html>
