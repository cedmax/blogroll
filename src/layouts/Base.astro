---
import "../styles/global.css"

interface Props {
  title: string
  description?: string
  canonical: string
  activeNav: "home" | "lista" | "info" | ""
  opmlFile: string
}
const { title, description, canonical, activeNav, opmlFile } = Astro.props
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="cedmax" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/opml+xml"
      title="Blogroll.it OPML"
      href={`https://blogroll.it/${opmlFile}`}
    />
    <meta name="theme-color" content="#f5f0e8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>
  <body class="bg-bg text-ink font-sans text-base leading-normal min-h-screen">
    <div class="max-w-4xl mx-auto px-5 pt-8 pb-16">
      <header
        class="flex relative items-center justify-between flex-wrap gap-x-4 gap-y-2 mb-16 pb-4 border-b border-border"
      >
        <a
          class="text-4xl font-black tracking-tighter text-green no-underline hover:text-green-h"
          href="/">Blogroll.it</a
        >
        <nav class="flex gap-5 text-sm">
          {
            activeNav === "home" ? (
              <span class="text-ink font-semibold">post recenti</span>
            ) : (
              <a class="text-ink-muted no-underline hover:text-green hover:underline" href="/">
                post recenti
              </a>
            )
          }
          {
            activeNav === "lista" ? (
              <span class="text-ink font-semibold">la lista</span>
            ) : (
              <a
                class="text-ink-muted no-underline hover:text-green hover:underline"
                href="/lista/"
              >
                la lista
              </a>
            )
          }
          {
            activeNav === "info" ? (
              <span class="text-ink font-semibold">il progetto</span>
            ) : (
              <a
                class="text-ink-muted no-underline hover:text-green hover:underline"
                href="/info/"
              >
                il progetto
              </a>
            )
          }

          <a
            class="text-ink-muted no-underline hover:text-green hover:underline"
            target="_blank"
            href={`/${opmlFile}`}>OPML</a
          >
        </nav>
        <div class="absolute -bottom-10 left-1">
          <slot name="meta-line" />
        </div>
      </header>

      <slot />

      <footer class="mt-12 pt-4 text-right border-t border-border text-xs text-ink-muted">
        <a
          class="text-green no-underline hover:text-green-h hover:underline"
          href="https://github.com/cedmax/blogroll/issues/new?template=add-feed.yml"
          >Suggerisci un sito</a
        >.
      </footer>
    </div>
  </body>
</html>

<script>
  const wireCopy = (link: HTMLAnchorElement | null, label: Element | null) => {
    if (!link || !label) return
    const original = label.textContent
    link.addEventListener("click", (e) => {
      e.preventDefault()
      navigator.clipboard.writeText(link.href).then(() => {
        label.textContent = "Link copiato"
        setTimeout(() => {
          label.textContent = original
        }, 1500)
      })
    })
  }

  // Desktop: RSS icon + hover tooltip (feedback = tooltip span)
  document.querySelectorAll(".feed-link").forEach((wrapper) => {
    wireCopy(wrapper.querySelector("a"), wrapper.querySelector("span"))
  })

  // Touch: menu row (feedback = the row label)
  document.querySelectorAll<HTMLAnchorElement>(".feed-copy").forEach((link) => {
    wireCopy(link, link.querySelector(".copy-label"))
  })

  // Close any open touch menu when tapping outside it
  document.addEventListener("click", (e) => {
    document.querySelectorAll<HTMLDetailsElement>("details.feed-menu[open]").forEach((menu) => {
      if (!menu.contains(e.target as Node)) menu.removeAttribute("open")
    })
  })
</script>
