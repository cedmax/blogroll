---
import "../styles/global.css"
import ThemeIcon from "../components/icons/ThemeIcon.astro"

interface Props {
  title: string
  description?: string
  canonical: string
  activeNav: "home" | "lista" | "info" | ""
  opmlFile: string
}
const { title, description, canonical, activeNav, opmlFile } = Astro.props
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="cedmax" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/opml+xml"
      title="blogroll.it OPML"
      href={`https://blogroll.it/${opmlFile}`}
    />
    <meta name="theme-color" content="#f5f0e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#15171a" media="(prefers-color-scheme: dark)" />
    <script is:inline>
      const t = localStorage.getItem("theme")
      if (t) document.documentElement.dataset.theme = t
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>
  <body class="bg-bg text-ink font-sans text-base leading-normal min-h-screen">
    <div class="max-w-4xl mx-auto px-5 pt-8 pb-16">
      <header
        class="flex relative items-center justify-between flex-wrap gap-x-4 gap-y-2 mb-16 pb-4 border-b border-border"
      >
        <a class="text-4xl font-black tracking-tighter no-underline" href="/">blogroll.it</a>
        <nav class="flex gap-5 text-sm">
          {
            activeNav === "home" ? (
              <span class="text-ink font-semibold">post recenti</span>
            ) : (
              <a class="text-ink-muted hover:text-accent" href="/">
                post recenti
              </a>
            )
          }
          {
            activeNav === "lista" ? (
              <span class="text-ink font-semibold">la lista</span>
            ) : (
              <a class="text-ink-muted hover:text-accent" href="/lista/">
                la lista
              </a>
            )
          }
          {
            activeNav === "info" ? (
              <span class="text-ink font-semibold">il progetto</span>
            ) : (
              <a class="text-ink-muted  hover:text-accent" href="/info/">
                il progetto
              </a>
            )
          }

          <a class="text-ink-muted hover:text-accent" target="_blank" href={`/${opmlFile}`}
            >OPML</a
          >
          <button
            id="theme-toggle"
            aria-label="Cambia tema"
            class="text-ink-muted hover:text-accent cursor-pointer bg-transparent border-0 p-0 leading-none"
          >
            <ThemeIcon />
          </button>
        </nav>
        <div class="absolute -bottom-10 left-1">
          <slot name="meta-line" />
        </div>
      </header>

      <slot />

      <footer class="mt-12 pt-4 text-right border-t border-border text-xs text-ink-muted">
        <a href="https://github.com/cedmax/blogroll/issues/new?template=add-feed.yml"
          >Suggerisci un sito</a
        >.
      </footer>
    </div>
    <script>
      const btn = document.getElementById("theme-toggle")
      btn?.addEventListener("click", () => {
        const el = document.documentElement
        const isDark =
          el.dataset.theme === "dark" ||
          (!el.dataset.theme && window.matchMedia("(prefers-color-scheme: dark)").matches)
        const next = isDark ? "light" : "dark"
        el.dataset.theme = next
        localStorage.setItem("theme", next)
      })
    </script>
  </body>
</html>
