---
import { fmtShort } from '../utils/dates'
interface Props { title: string; url: string; published: string }
const { title, url, published } = Astro.props
---
<div class="grid grid-cols-[110px_1fr] border-b border-border-l last:border-b-0 even:bg-alt max-sm:block max-sm:py-2 max-sm:px-3.5">
  <span class="py-2 px-3 text-xs text-ink-muted whitespace-nowrap border-r border-border-l flex flex-col justify-center max-sm:block max-sm:border-r-0 max-sm:p-0 max-sm:pb-1">
    {fmtShort(new Date(published))}
  </span>
  <a class="py-2 px-3.5 flex items-center text-sm text-ink no-underline leading-snug visited:text-ink-muted hover:text-green hover:underline max-sm:block max-sm:p-0" href={url} target="_blank" rel="noopener noreferrer">{title}</a>
</div>
