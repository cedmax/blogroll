---
interface Props {
  url: string
  size?: string
}

const { url, size = "14" } = Astro.props
---

<a
  class="no-underline inline-flex items-center hover:text-green"
  href={url}
  rel="noopener noreferrer"
  target="_blank"
  aria-label="Feed RSS"
>
  <svg width={size} height={size} viewBox="0 0 12 12" fill="currentColor" aria-hidden="true"
    ><circle cx="2" cy="10" r="1.5"></circle><path
      d="M1 6.5A5.5 5.5 0 0 1 6.5 12H8A6.5 6.5 0 0 0 1 5.5v1z"></path><path
      d="M1 3A9 9 0 0 1 10 12h1.5A10.5 10.5 0 0 0 1 1.5V3z"></path></svg
  >
</a>
