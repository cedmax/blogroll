---
import ExternalIcon from "./icons/ExternalIcon.astro"
import RssIcon from "./icons/RssIcon.astro"
import WarningIcon from "./icons/WarningIcon.astro"
import { reportUrl, type Feed } from "../utils/feeds"

interface Props {
  feed: Feed
  size?: string
  showReport?: boolean
}

const { feed, showReport = false } = Astro.props
---

<details class="relative feed-menu">
  <summary
    class="flex items-center justify-center w-9 h-9 -my-1 -mr-2 cursor-pointer list-none text-ink hover:text-green [&::-webkit-details-marker]:hidden"
  >
    <span class="sr-only">Azioni</span>
    <svg
      width="20"
      height="20"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentcolor"
      aria-hidden="true"
    >
      <circle cx="12" cy="5" r="2"></circle>
      <circle cx="12" cy="12" r="2"></circle>
      <circle cx="12" cy="19" r="2"></circle>
    </svg>
  </summary>

  <div
    class="absolute font-light text-sm right-0 top-full z-20 mt-1 min-w-56 rounded-md border border-border bg-card shadow-lg overflow-hidden"
  >
    <a
      href={feed.htmlUrl}
      target="_blank"
      class="flex items-center gap-3 px-4 py-3 min-h-11 text-ink no-underline hover:bg-bg"
    >
      <ExternalIcon size="18" />
      Vai al sito
    </a>
    <a
      href={feed.xmlUrl}
      data-copy
      class="feed-copy flex items-center gap-3 px-4 py-3 min-h-11 text-ink no-underline hover:bg-bg"
    >
      <RssIcon size="18" />
      <span class="copy-label">Copia il link del feed</span>
    </a>
    {
      showReport && (
        <a
          href={reportUrl(feed.htmlUrl)}
          target="_blank"
          class="flex items-center gap-3 px-4 py-3 min-h-11 text-ink no-underline hover:bg-bg"
        >
          <WarningIcon size="18" />
          Segnala il sito
        </a>
      )
    }
  </div>
</details>
