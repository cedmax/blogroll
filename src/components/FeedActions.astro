---
import ExternalIcon from "./icons/ExternalIcon.astro"
import RssIcon from "./icons/RssIcon.astro"
import WarningIcon from "./icons/WarningIcon.astro"
import type { Feed } from "../utils/feeds"

interface Props {
  feed: Feed
}

const { feed } = Astro.props

const rowClass = "flex items-center gap-3 px-4 py-3 min-h-11 text-ink no-underline hover:bg-bg"
---

<details class="relative feed-menu">
  <summary
    class="flex items-center justify-center w-9 h-9 -my-1 -mr-2 cursor-pointer list-none text-ink hover:text-accent [&::-webkit-details-marker]:hidden"
  >
    <span class="sr-only">Azioni</span>
    <svg
      width="20"
      height="20"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentcolor"
      aria-hidden="true"
    >
      <circle cx="12" cy="5" r="2"></circle>
      <circle cx="12" cy="12" r="2"></circle>
      <circle cx="12" cy="19" r="2"></circle>
    </svg>
  </summary>

  <div
    class="absolute font-light text-sm right-0 top-full z-20 mt-1 min-w-56 rounded-md border border-border bg-card shadow-lg overflow-hidden"
  >
    <a href={feed.htmlUrl} target="_blank" class={rowClass}>
      <ExternalIcon size="18" />
      Vai al sito
    </a>
    <a href={feed.xmlUrl} target="_blank" class:list={["feed-copy", rowClass]}>
      <RssIcon size="18" />
      <span class="copy-label">Copia il link del feed</span>
    </a>

    <button
      type="button"
      class:list={["report-trigger w-full bg-transparent border-0 cursor-pointer", rowClass]}
      data-site-url={feed.htmlUrl}
    >
      <WarningIcon size="18" />
      Segnala il sito
    </button>
  </div>
</details>

<script>
  const wireCopy = (link: HTMLAnchorElement | null, label: Element | null) => {
    if (!link || !label) return
    const original = label.textContent
    link.addEventListener("click", (e) => {
      e.preventDefault()
      navigator.clipboard.writeText(link.href).then(() => {
        label.textContent = "Link copiato"
        setTimeout(() => {
          label.textContent = original
        }, 1500)
      })
    })
  }

  // Copy the feed URL from the actions menu (feedback = the row label)
  document.querySelectorAll<HTMLAnchorElement>(".feed-copy").forEach((link) => {
    wireCopy(link, link.querySelector(".copy-label"))
  })

  // Close any open menu when clicking outside it
  document.addEventListener("click", (e) => {
    document.querySelectorAll<HTMLDetailsElement>("details.feed-menu[open]").forEach((menu) => {
      if (!menu.contains(e.target as Node)) menu.removeAttribute("open")
    })
  })
</script>
