---
const { url, size } = Astro.props
---

<a
  class="no-underline inline-flex items-center hover:text-green"
  href={url}
  rel="noopener noreferrer"
  target="_blank"
  aria-label="Visita il sito"
>
  <svg
    width={size}
    height={size}
    viewBox="0 -2 12 14"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    ><path d="M5 2H2a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h7a1 1 0 0 0 1-1V7"></path><path d="M8 1h3v3"
    ></path><line x1="11" y1="1" x2="5.5" y2="6.5"></line></svg
  >
</a>
