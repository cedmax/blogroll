---
import Base from "../layouts/Base.astro";
import { getFeeds, builtAt, opmlFile } from "../utils/feeds";
import { fmtLong } from "../utils/dates";

const feeds = await getFeeds();

const MAX_DAYS = 60;
const cutoff = Date.now() - MAX_DAYS * 24 * 60 * 60 * 1000;
const entries = feeds
  .flatMap((feed) =>
    feed.entries
      .filter((e) => new Date(e.published).getTime() >= cutoff)
      .map((e) => ({ ...e, blogName: feed.title, blogSlug: feed.slug })),
  )
  .sort(
    (a, b) => new Date(b.published).getTime() - new Date(a.published).getTime(),
  );
const entryCount = entries.length;
const groupDates = [...new Set(entries.map((e) => e.published.slice(0, 10)))];
const byDate = Object.groupBy(entries, (e) => e.published.slice(0, 10));
---

<Base
  title={`Blogroll.it — ${entryCount} post da ${feeds.length} blog`}
  description={`Post recenti da ${feeds.length} blog personali italiani, aggiornati ogni poche ore. Niente algoritmi, niente account, solo link.`}
  canonical="https://blogroll.it/"
  activeNav="home"
  opmlFile={opmlFile}
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Blogroll.it" />
    <meta property="og:description" content={`Post recenti da ${feeds.length} blog personali italiani, aggiornati ogni poche ore.`} />
    <meta property="og:url" content="https://blogroll.it/" />
    <meta property="og:site_name" content="Blogroll.it" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Blogroll.it" />
    <meta name="twitter:description" content={`Post recenti da ${feeds.length} blog personali italiani, aggiornati ogni poche ore.`} />
  </Fragment>

  <p class="text-xs text-ink-muted mb-4" slot="meta-line">
    {entryCount} post da {feeds.length} blog negli ultimi {MAX_DAYS} giorni &mdash; {builtAt}
  </p>

  {
    groupDates.map((date) => (
      <div class="mb-4">
        <h2 class="text-xs font-semibold tracking-widest uppercase text-ink-muted mb-1.5 pl-4">{fmtLong(new Date(date))}</h2>
        <div class="entries">
          {byDate[date]!.map((entry) => (
            <div class="grid grid-cols-[185px_1fr] border-b border-border-l last:border-b-0 even:bg-alt max-sm:block max-sm:py-2 max-sm:px-3">
              <span class="py-2 px-3 text-sm font-medium text-green whitespace-nowrap overflow-hidden text-ellipsis border-r border-border-l flex items-center max-sm:block max-sm:border-r-0 max-sm:p-0 max-sm:pb-1 max-sm:text-xs">
                <a class="text-inherit no-underline hover:text-green-h hover:underline" href={`/sites/${entry.blogSlug}/`}>{entry.blogName}</a>
              </span>
              <span class="py-2 px-3.5 flex items-center max-sm:block max-sm:p-0">
                <a class="text-sm text-ink no-underline leading-snug visited:text-ink-muted hover:text-green hover:underline" href={entry.url} target="_blank" rel="noopener noreferrer">{entry.title}</a>
              </span>
            </div>
          ))}
        </div>
      </div>
    ))
  }
</Base>
