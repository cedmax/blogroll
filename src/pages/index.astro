---
import Base from "../layouts/Base.astro"
import { getFeeds, builtAt } from "../utils/feeds"
import { fmtLong, dayKey } from "../utils/dates"
import FeedHeader from "../components/FeedHeader.astro"
import Card from "../components/Card.astro"
import SocialMeta from "../components/SocialMeta.astro"
import MetaLine from "../components/MetaLine.astro"

const feeds = await getFeeds()

const MAX_DAYS = 30
const cutoff = Date.now() - MAX_DAYS * 24 * 60 * 60 * 1000
const entries = feeds
  .flatMap(({ entries, ...feed }) =>
    entries
      .filter((e) => new Date(e.published).getTime() >= cutoff)
      .map((e) => ({ ...e, feed })),
  )
  .sort((a, b) => new Date(b.published).getTime() - new Date(a.published).getTime())

const allUrls = entries.map(({ url }) => url)
const entryCount = entries.length
// The YYYY-MM-DD day keys are parsed back with new Date(), i.e. UTC midnight;
// fmtLong then renders them in Europe/Rome on the same calendar day only
// because Rome is always at or ahead of UTC.
const groupDates = [...new Set(entries.map((e) => dayKey(new Date(e.published))))]
const byDate = Object.groupBy(entries, (e) => dayKey(new Date(e.published)))

function collapseByFeed(dayEntries: typeof entries) {
  const feedGroups = new Map<string, typeof entries>()
  for (const e of dayEntries) {
    const slug = e.feed.slug
    if (!feedGroups.has(slug)) feedGroups.set(slug, [])
    feedGroups.get(slug)!.push(e)
  }
  const keep = new Map<(typeof entries)[0], number>()
  for (const group of feedGroups.values()) {
    keep.set(group[group.length - 1], group.length - 1)
  }
  return dayEntries.filter((e) => keep.has(e)).map((e) => ({ ...e, extraCount: keep.get(e)! }))
}

const collapsedByDate = Object.fromEntries(
  groupDates.map((date) => [date, collapseByFeed(byDate[date]!)]),
)
---

<Base
  title={`blogroll.it — ${entryCount} post da ${feeds.length} siti`}
  description={`Post recenti da ${feeds.length} siti personali italiani, aggiornati ogni poche ore. Niente algoritmi, niente account, solo link.`}
  canonical="https://blogroll.it/"
  activeNav="home"
>
  <Fragment slot="head">
    <SocialMeta
      title="blogroll.it"
      description={`Post recenti da ${feeds.length} siti personali italiani, aggiornati ogni poche ore.`}
      url="https://blogroll.it/"
    />
  </Fragment>

  <MetaLine slot="meta-line">
    {entryCount} post da {feeds.length} siti negli ultimi {MAX_DAYS} giorni &mdash; {builtAt}
  </MetaLine>

  <div
    class="bg-alt border border-border rounded prose mt-12 py-5 px-6 mb-10 text-base italic text-ink font-light"
  >
    blogroll.it è una raccolta curata di siti personali in italiano, aggiornata regolarmente e
    senza algoritmi o account. Se non sai cosa fare, leggi del {" "}
    <a class="underline" href="/info/" aria-label="Il progetto">progetto</a> o {" "}
    <a id="lucky" class="underline" href="#" aria-label="Un post a caso">un post a caso</a>.
  </div>

  {
    groupDates.map((date) => (
      <div class="mb-6">
        <h2 class="text-3xl font-black tracking-tight text-ink-muted mb-3 pb-2 border-b-2 border-ink-muted">
          {fmtLong(new Date(date))}
        </h2>
        {collapsedByDate[date]!.map((entry) => (
          <Card class="pb-1.5 mb-2">
            <div class="bg-card block rounded border-b border-border-l px-3 py-2.5">
              <a
                class="pr inline-flex items-center text-base font-semibold leading-snug visited:text-ink-muted"
                href={entry.url}
                target="_blank"
              >
                {entry.title}{" "}
              </a>{" "}
              {entry.extraCount > 0 && (
                <a
                  class="pr-3 text-xs text-ink-muted inline"
                  href={`/sites/${entry.feed.slug}/`}
                >
                  + {entry.extraCount === 1 ? "un altro" : `altri ${entry.extraCount}`} post
                </a>
              )}
            </div>
            <div class="px-3 pt-0.5 text-ink-muted flex items-center gap-2 justify-center">
              <FeedHeader feed={entry.feed} titleClass="text-xs" />
            </div>
          </Card>
        ))}
      </div>
    ))
  }
</Base>

<script define:vars={{ allUrls }}>
  document.getElementById("lucky").addEventListener("click", (e) => {
    e.preventDefault()
    const url = allUrls[Math.floor(Math.random() * allUrls.length)]
    if (url) window.open(url, "_blank")
  })
</script>
