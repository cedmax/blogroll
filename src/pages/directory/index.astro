---
import Base from "../../layouts/Base.astro";
import EntryRow from "../../components/EntryRow.astro";
import { getFeeds, sortFeedsByLatest, builtAt, opmlFile } from "../../utils/feeds";

const feeds = sortFeedsByLatest(await getFeeds());
---

<Base
  title={`Blogroll.it — La lista (${feeds.length} blog)`}
  description={`Tutti i ${feeds.length} blog personali italiani raccolti in Blogroll.it.`}
  canonical="https://blogroll.it/directory/"
  activeNav="lista"
  opmlFile={opmlFile}
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Blogroll.it — La lista" />
    <meta property="og:description" content={`Tutti i ${feeds.length} blog personali italiani raccolti in Blogroll.it.`} />
    <meta property="og:url" content="https://blogroll.it/directory/" />
    <meta property="og:site_name" content="Blogroll.it" />
  </Fragment>

  <p class="text-xs text-ink-muted mb-4" slot="meta-line">
    {feeds.length} blog — aggiornato il {builtAt}
  </p>

  <div class="flex flex-col gap-4">
    {
      feeds.map((feed) => (
        <div class="bg-card border border-border rounded-lg p-4 flex flex-col gap-1 overflow-hidden">
          <div class="text-sm font-semibold flex items-center gap-2">
            <a class="text-green no-underline flex-1 hover:text-green-h hover:underline" href={`/sites/${feed.slug}/`}>{feed.title}</a>
            <a class="text-ink-muted no-underline inline-flex items-center hover:text-green" href={feed.htmlUrl} rel="noopener noreferrer" target="_blank" aria-label="Visita il sito">
              <svg width="14" height="14" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 2H2a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h7a1 1 0 0 0 1-1V7"/><path d="M8 1h3v3"/><line x1="11" y1="1" x2="5.5" y2="6.5"/></svg>
            </a>
            <a class="text-ink-muted no-underline inline-flex items-center hover:text-green" href={feed.xmlUrl} rel="noopener noreferrer" target="_blank" aria-label="Feed RSS">
              <svg width="14" height="14" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true"><circle cx="2" cy="10" r="1.5"/><path d="M1 6.5A5.5 5.5 0 0 1 6.5 12H8A6.5 6.5 0 0 0 1 5.5v1z"/><path d="M1 3A9 9 0 0 1 10 12h1.5A10.5 10.5 0 0 0 1 1.5V3z"/></svg>
            </a>
          </div>
          {feed.description && <div class="text-sm text-ink-mid leading-relaxed">{feed.description}</div>}
          {feed.entries[0] && (
            <div class="-mx-4 -mb-4 mt-2 border-t border-border-l bg-alt max-sm:-mx-3.5 max-sm:-mb-3.5">
              <EntryRow {...feed.entries[0]} />
            </div>
          )}
        </div>
      ))
    }
  </div>
</Base>
