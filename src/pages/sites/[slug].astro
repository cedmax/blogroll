---
import Base from "../../layouts/Base.astro"
import EntryRow from "../../components/EntryRow.astro"
import { getFeeds, builtAt, opmlFile } from "../../utils/feeds"
import FeedHeader from "../../components/FeedHeader.astro"
import SocialMeta from "../../components/SocialMeta.astro"
import MetaLine from "../../components/MetaLine.astro"

export async function getStaticPaths() {
  const feeds = await getFeeds()
  return feeds.map((feed) => ({ params: { slug: feed.slug }, props: { feed } }))
}

const { feed } = Astro.props
---

<Base
  title={`${feed.title} — Blogroll.it`}
  description={feed.description}
  canonical={`https://blogroll.it/sites/${feed.slug}/`}
  activeNav=""
  opmlFile={opmlFile}
>
  <Fragment slot="head">
    <SocialMeta
      title={`${feed.title} — Blogroll.it`}
      description={feed.description}
      url={`https://blogroll.it/sites/${feed.slug}/`}
    />
  </Fragment>

  <MetaLine slot="meta-line">aggiornato il {builtAt}</MetaLine>

  <div class="bg-card border border-border rounded py-4 px-5 mb-4">
    <div class="text-lg font-bold mb-1 flex items-baseline gap-2 flex-wrap">
      <FeedHeader feed={feed} size="16" linked={false} titleClass="text-lg font-bold" />
    </div>
    {
      feed.description && (
        <div class="text-sm text-ink-muted leading-relaxed">{feed.description}</div>
      )
    }
  </div>

  <div class="bg-card border border-border rounded overflow-hidden">
    {feed.entries.map((entry) => <EntryRow {...entry} />)}
  </div>
</Base>
