---
import Base from "../../layouts/Base.astro"
import EntryRow from "../../components/EntryRow.astro"
import { getFeeds, builtAt, opmlFile } from "../../utils/feeds"

export async function getStaticPaths() {
  const feeds = await getFeeds()
  return feeds.map((feed) => ({ params: { slug: feed.slug }, props: { feed } }))
}

const { feed } = Astro.props
---

<Base
  title={`${feed.title} — Blogroll.it`}
  description={feed.description}
  canonical={`https://blogroll.it/sites/${feed.slug}/`}
  activeNav=""
  opmlFile={opmlFile}
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${feed.title} — Blogroll.it`} />
    <meta property="og:description" content={feed.description} />
    <meta property="og:url" content={`https://blogroll.it/sites/${feed.slug}/`} />
    <meta property="og:site_name" content="Blogroll.it" />
  </Fragment>

  <p class="text-xs text-ink-muted mb-4" slot="meta-line">aggiornato il {builtAt}</p>

  <div class="bg-card border border-border rounded-lg p-4 mb-4">
    <div class="text-lg font-bold mb-1 flex items-baseline gap-2 flex-wrap">
      <span class="flex-1">{feed.title}</span>
      <a
        class="text-xs font-normal text-ink-muted no-underline inline-flex items-center hover:text-green"
        href={feed.htmlUrl}
        rel="noopener noreferrer"
        target="_blank"
        aria-label="Visita il sito"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><path d="M5 2H2a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h7a1 1 0 0 0 1-1V7"></path><path
            d="M8 1h3v3"></path><line x1="11" y1="1" x2="5.5" y2="6.5"></line></svg
        >
      </a>
      <a
        class="text-xs font-normal text-ink-muted no-underline inline-flex items-center hover:text-green"
        href={feed.xmlUrl}
        rel="noopener noreferrer"
        target="_blank"
        aria-label="Feed RSS"
      >
        <svg width="14" height="14" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true"
          ><circle cx="2" cy="10" r="1.5"></circle><path
            d="M1 6.5A5.5 5.5 0 0 1 6.5 12H8A6.5 6.5 0 0 0 1 5.5v1z"></path><path
            d="M1 3A9 9 0 0 1 10 12h1.5A10.5 10.5 0 0 0 1 1.5V3z"></path></svg
        >
      </a>
    </div>
    {
      feed.description && (
        <div class="text-sm text-ink-mid leading-relaxed">{feed.description}</div>
      )
    }
  </div>

  <div class="entries">
    {
      feed.entries.length > 0 ? (
        feed.entries.map((entry) => <EntryRow {...entry} />)
      ) : (
        <div class="p-4 text-sm text-ink-muted italic">Nessun post disponibile al momento.</div>
      )
    }
  </div>
</Base>
