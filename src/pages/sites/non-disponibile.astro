---
import NotFoundText from "../../components/NotFoundText.astro"
import Base from "../../layouts/Base.astro"
import { opmlFile } from "../../utils/feeds"
---

<Base
  title="Blog temporaneamente non disponibile — Blogroll.it"
  description="Questo blog fa parte della lista, ma l'ultimo recupero del suo feed non è riuscito."
  canonical="https://blogroll.it/sites/non-disponibile/"
  activeNav=""
  opmlFile={opmlFile}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <div class="bg-card border border-border rounded py-6 px-5">
    <h1 class="text-lg font-bold mb-3">Blog temporaneamente non disponibile</h1>
    <p class="text-sm text-ink-muted leading-relaxed mb-3">
      Questo blog fa parte della lista, ma l'ultimo tentativo di recupero del suo feed non è
      andato a buon fine. Non è sparito: dovrebbe tornare al prossimo aggiornamento.
    </p>
    <p class="text-sm text-ink-muted leading-relaxed">
      Nel frattempo puoi <NotFoundText />.
    </p>
  </div>
</Base>
