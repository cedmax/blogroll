---
import Base from "../layouts/Base.astro"
import EntryRow from "../components/EntryRow.astro"
import { getFeeds, sortFeedsByLatest, builtAt } from "../utils/feeds"
import FeedHeader from "../components/FeedHeader.astro"
import Card from "../components/Card.astro"
import SocialMeta from "../components/SocialMeta.astro"
import MetaLine from "../components/MetaLine.astro"

const feeds = sortFeedsByLatest(await getFeeds())
---

<Base
  title={`blogroll.it — La lista (${feeds.length} siti)`}
  description={`Tutti i ${feeds.length} siti personali italiani raccolti in blogroll.it.`}
  canonical="https://blogroll.it/lista/"
  activeNav="lista"
>
  <Fragment slot="head">
    <SocialMeta
      title="blogroll.it — La lista"
      description={`Tutti i ${feeds.length} siti personali italiani raccolti in blogroll.it.`}
      url="https://blogroll.it/lista/"
    />
  </Fragment>

  <MetaLine slot="meta-line">{feeds.length} siti — aggiornato il {builtAt}</MetaLine>

  <div class="flex flex-col gap-4">
    {
      feeds.map((feed) => (
        <Card>
          <div class="py-2.5 px-3 bg-card rounded border-b border-border-l flex items-center gap-2 justify-center">
            <FeedHeader feed={feed} titleClass="text-base font-bold leading-snug" />
          </div>

          <div class="-mt-1">
            <EntryRow {...feed.entries[0]} />
          </div>
        </Card>
      ))
    }
  </div>
</Base>
