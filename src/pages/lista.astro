---
import Base from "../layouts/Base.astro"
import EntryRow from "../components/EntryRow.astro"
import { getFeeds, sortFeedsByLatest, builtAt, opmlFile } from "../utils/feeds"
import BlogRow from "../components/BlogRow.astro"
import BlogLink from "../components/BlogLink.astro"
import FeedLink from "../components/FeedLink.astro"

const feeds = sortFeedsByLatest(await getFeeds())
---

<Base
  title={`Blogroll.it — La lista (${feeds.length} blog)`}
  description={`Tutti i ${feeds.length} blog personali italiani raccolti in Blogroll.it.`}
  canonical="https://blogroll.it/directory/"
  activeNav="lista"
  opmlFile={opmlFile}
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Blogroll.it — La lista" />
    <meta
      property="og:description"
      content={`Tutti i ${feeds.length} blog personali italiani raccolti in Blogroll.it.`}
    />
    <meta property="og:url" content="https://blogroll.it/directory/" />
    <meta property="og:site_name" content="Blogroll.it" />
  </Fragment>

  <p class="text-xs text-ink-muted mb-4" slot="meta-line">
    {feeds.length} blog — aggiornato il {builtAt}
  </p>

  <div class="flex flex-col gap-4">
    {
      feeds.map((feed) => (
        <div class="bg-alt border border-border rounded-lg  flex flex-col gap-1 overflow-hidden">
          <div class="py-2.5 px-3 bg-card border-b border-border-l flex items-center gap-2 justify-center">
            <a
              class="flex-1 items-center text-base font-semibold text-green no-underline leading-snug visited:text-ink-muted hover:text-green-h hover:underline"
              href={`/sites/${feed.slug}/`}
            >
              {feed.title}
            </a>
            <BlogLink size="14" url={feed.htmlUrl} />
            <FeedLink size="14" url={feed.xmlUrl} />
          </div>

          <div class="-mt-1">
            <EntryRow {...feed.entries[0]} />
          </div>
        </div>
      ))
    }
  </div>
</Base>
